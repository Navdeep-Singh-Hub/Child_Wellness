# Copy this file to .env in this same folder (backend/.env), then edit values.

MONGODB_URI=mongodb://127.0.0.1:27017/child_wellness
PORT=4000

# Expo web on http://192.168.x.x:8081 → allow browser CORS to this API (:4000)
# ALLOW_LAN_CORS=1

# --- Letter copy games: POST /api/validate-letter (OpenAI vision) ---
# Without this, the app shows: "Letter check is not set up yet..."
# 1. Create a key at https://platform.openai.com/api-keys
# 2. Put one line in backend/.env (no quotes):
#    OPENAI_API_KEY=sk-...
# 3. Restart the Node server (backend).
# On Render/hosting: add OPENAI_API_KEY in the service Environment tab and redeploy.
OPENAI_API_KEY=
